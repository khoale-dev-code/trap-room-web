NODE_ENV=production
SERVE_FRONTEND=false
ALLOW_VERCEL_PREVIEWS=true

# Railway injects PORT automatically. Do not set PORT manually.
CLIENT_ORIGINS=https://YOUR-PROJECT.vercel.app

MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@YOUR-CLUSTER.mongodb.net/trap_room?retryWrites=true&w=majority

ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
ADMIN_JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
ADMIN_COOKIE_NAME=trap_admin_token

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=trap-room
